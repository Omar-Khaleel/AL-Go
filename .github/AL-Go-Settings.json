{
  "type": "PTE",
  "templateUrl": "https://github.com/microsoft/AL-Go-PTE@main",
  "appFolders": [
    "app"
  ],
  "environments": [
    "Sandbox"
  ],
  "DeployToSandbox": {
    "EnvironmentType": "Sandbox",
    "EnvironmentName": "Sandbox",
    "Scope": "Dev",
    "continuousDeployment": true,
    "runs-on": "windows-latest",
    "shell": "powershell",
    "DependencyInstallMode": "install"
  }
}
